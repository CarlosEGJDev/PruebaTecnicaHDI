@page "/clientes"
@using System.Net.Http.Json
@using Components.Models
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Clientes de Oracle</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill"></i> Listado de Clientes (Oracle)</h2>
        <button class="btn btn-primary" @onclick="CargarClientes">
            <i class="bi bi-arrow-clockwise"></i> Actualizar
        </button>
    </div>

    @if (errorMsg != null)
    {
        <div class="alert alert-danger" role="alert">
            <h5><i class="bi bi-exclamation-triangle-fill"></i> Error de conexión</h5>
            <p>@errorMsg</p>
        </div>
    }
    else if (clientes == null)
    {
        <div class="d-flex align-items-center justify-content-center my-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <h4 class="ms-3 mb-0 text-muted">Consultando la base de datos Oracle...</h4>
        </div>
    }
    else if (!clientes.Any())
    {
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-info-circle-fill"></i> No se encontraron clientes registrados en el sistema.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 10%">ID</th>
                            <th style="width: 45%">Nombre</th>
                            <th style="width: 45%">Correo Electrónico</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cliente in clientes)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@cliente.Id</span></td>
                                <td><strong>@cliente.Nombre</strong></td>
                                <td><a href="mailto:@cliente.Email">@cliente.Email</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<ClienteDTO>? clientes;
    private string? errorMsg;

    // Este método se ejecuta automáticamente cuando el usuario entra a la página
    protected override async Task OnInitializedAsync()
    {
        await CargarClientes();
    }

    private async Task CargarClientes()
    {
        clientes = null; // Muestra el spinner de carga
        errorMsg = null;

        try
        {
            // Creamos el cliente usando el alias "CustomerAPI" que definimos en tu Program.cs
            var httpClient = HttpClientFactory.CreateClient("CustomerAPI");

            // Hacemos el GET a "api/cliente" (fíjate que tu controller se llama ClienteController, así que la ruta es 'api/cliente')
            clientes = await httpClient.GetFromJsonAsync<List<ClienteDTO>>("api/cliente");
        }
        catch (Exception ex)
        {
            errorMsg = $"No se pudo obtener la información de la API. Detalle: {ex.Message}";
            clientes = new List<ClienteDTO>(); // Inicializamos vacío para detener el spinner
        }
    }
}